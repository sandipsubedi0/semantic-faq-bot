   "source": [
    "## 7. Interactive chat mode\n",
    "\n",
    "Run this cell to type your own questions directly. Type `exit` or `quit` to stop."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "187c67c2",
   "metadata": {},
   "outputs": [],
   "source": [
    "while True:\n",
    "    user_input = input(\"You: \")\n",
    "    if user_input.lower() in {\"exit\", \"quit\"}:\n",
    "        print(\"Goodbye!\")\n",
    "        break\n",
    "    ask_question(user_input)\n"
   ]
